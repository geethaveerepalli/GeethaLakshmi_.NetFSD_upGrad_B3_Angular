@model List<WebApplication5.Models.ContactInfo>

<h2>All Contacts</h2>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>Mobile</th>
        <th>Designation</th>
        <th>Company</th>
        <th>Department</th>
        <th>Actions</th>
    </tr>

    @foreach (var c in Model)
    {
        <tr>
            <td>@c.ContactId</td>
            <td>@c.FirstName @c.LastName</td>
            <td>@c.EmailId</td>
            <td>@c.MobileNo</td>
            <td>@c.Designation</td>
            <td>@c.Company?.CompanyName</td>
            <td>@c.Department?.DepartmentName</td>
            <td>
                <a asp-action="Details" asp-route-id="@c.ContactId">View</a> |
                <a asp-action="EditContact" asp-route-id="@c.ContactId">Edit</a> |
                <a asp-action="DeleteContact" asp-route-id="@c.ContactId"
                   onclick="return confirm('Are you sure?')">Delete</a>
            </td>
        </tr>
    }
</table>

<a asp-action="AddContact" class="btn btn-success">Add New Contact</a>