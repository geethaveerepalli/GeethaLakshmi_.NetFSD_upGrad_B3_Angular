@model List<WebApplication5.Models.Course>

<table class="table">

    <tr>
        <td>Course Id</td>
        <td>Course Name</td>
        <td>Students</td>
    </tr>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.CourseId</td>
            <td>@item.CourseName</td>
            <td>
                <ul>
                    @foreach(var stu in item.Students)
                    {
                        <li>@stu.StudentName</li>
                    }
                </ul>
            </td>
        </tr>
    }
</table>